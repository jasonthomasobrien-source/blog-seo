# ── Auth ──────────────────────────────────────────────────────────────────────
# Password for the dashboard (you choose — e.g. "rankready2026")
APP_PASSWORD=your-chosen-password

# Optional: demo password for "Try the Demo" button
# DEMO_PASSWORD=demo123

# Google OAuth (optional — enables "Sign in with Google" button)
# Set up at console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URI: https://your-app.vercel.app/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret
ALLOWED_EMAIL=your@gmail.com   # Only this Google account can log in

# Your deployed URL (used to build the Google OAuth redirect URI)
# On Vercel this is auto-set via VERCEL_URL — only needed for custom domains
# APP_URL=https://your-custom-domain.com

# ── Infrastructure ─────────────────────────────────────────────────────────────
# Vercel Blob (auto-populated when you add Blob storage in Vercel dashboard)
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# Upstash Redis (auto-injected by Vercel Marketplace integration)

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Tavily (research)
TAVILY_API_KEY=tvly-...

# Notion
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=your_notion_database_id

# Images (one or both)
UNSPLASH_ACCESS_KEY=your_unsplash_key
LEONARDO_API_KEY=your_leonardo_key

# Upstash Redis (auto-injected when you add Upstash from Vercel Marketplace)
UPSTASH_REDIS_REST_URL=https://....upstash.io
UPSTASH_REDIS_REST_TOKEN=...
